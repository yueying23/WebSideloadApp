# WebSideloadApp Docker Configuration Example
# Copy this file to .env and modify as needed

# ===========================================
# Authentication Configuration (Optional but Recommended)
# ===========================================

# Method 1: Plain text password (easier setup, less secure)
# WARNING: Not recommended for production environments
ACCESS_PASSWORD=your_secure_password_here

# Method 2: SHA-256 hash (more secure, recommended for production)
# Generate with: echo -n "your_password" | sha256sum
# Or on Windows PowerShell: $bytes = [System.Text.Encoding]::UTF8.GetBytes("your_password"); [Convert]::ToHexString((New-Object System.Security.Cryptography.SHA256Managed).ComputeHash($bytes))
# ACCESS_TOKEN_HASH=a665a45920422f9d417e4867efdc4fb8a04a1f3fff1fa07e998e86f7f7a27ae3

# NOTE: Use ONLY ONE method above. If both are set, ACCESS_TOKEN_HASH takes precedence.

# ===========================================
# Advanced Configuration
# ===========================================

# Custom token parameter name (default: "token")
# The WISP URL will be: wss://your-domain/wisp/?token=xxx
TOKEN_PARAM_NAME=token

# Server port (default: 3000)
PORT=3000

# ===========================================
# Usage Examples
# ===========================================

# 1. Frontend only (no authentication, no WISP proxy):
#    docker compose --profile frontend up -d

# 2. Full stack without authentication (development only):
#    docker compose --profile full up -d

# 3. Full stack with password authentication:
#    ACCESS_PASSWORD=mysecret docker compose --profile full up -d

# 4. Full stack with hashed token (production):
#    ACCESS_TOKEN_HASH=$(echo -n "mysecret" | sha256sum | awk '{print $1}') docker compose --profile full up -d

# 5. Using .env file:
#    cp .env.example .env
#    # Edit .env with your settings
#    docker compose --profile full up -d
