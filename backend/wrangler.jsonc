{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "web-sideload-app",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-03",
  "assets": {
    "directory": "../frontend/dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 0.1
  }
}
